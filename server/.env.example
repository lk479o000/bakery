# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=bakery
DB_USER=root
DB_PASSWORD=root123

# JWT 配置
JWT_SECRET=bakery_jwt_dev_secret_2026
JWT_EXPIRES_IN=7d

# 微信小程序配置（可选）
WX_APPID=
WX_SECRET=

# 服务器端口
PORT=8150

# 日志级别
LOG_LEVEL=debug

# ========== 文件上传配置 ==========

# 上传模式：local | oss（开发阶段使用 local）
UPLOAD_MODE=local

# 本地上传目录（相对于 server/）
UPLOAD_LOCAL_DIR=public/images

# 上传文件大小限制（MB），默认 10
UPLOAD_MAX_SIZE=10

# 允许上传的文件类型
UPLOAD_ALLOW_TYPES=image/jpeg,image/png,image/gif,image/webp,image/svg+xml

# OSS 提供商（mode=oss 时生效）：aliyun | tencent | qiniu | aws
# UPLOAD_OSS_PROVIDER=aliyun

# ----- 阿里云 OSS -----
# OSS_ALIYUN_REGION=oss-cn-hangzhou
# OSS_ALIYUN_ACCESS_KEY_ID=
# OSS_ALIYUN_ACCESS_KEY_SECRET=
# OSS_ALIYUN_BUCKET=my-bakery-bucket
# OSS_ALIYUN_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
# OSS_ALIYUN_CDN_DOMAIN=

# ----- 腾讯云 COS -----
# OSS_TENCENT_REGION=ap-guangzhou
# OSS_TENCENT_SECRET_ID=
# OSS_TENCENT_SECRET_KEY=
# OSS_TENCENT_BUCKET=
# OSS_TENCENT_CDN_DOMAIN=

# ----- 七牛云 Kodo -----
# OSS_QINIU_ACCESS_KEY=
# OSS_QINIU_SECRET_KEY=
# OSS_QINIU_BUCKET=
# OSS_QINIU_DOMAIN=
# OSS_QINIU_ZONE=z0

# ----- AWS S3 / MinIO -----
# OSS_AWS_REGION=us-east-1
# OSS_AWS_ACCESS_KEY_ID=
# OSS_AWS_SECRET_ACCESS_KEY=
# OSS_AWS_BUCKET=
# OSS_AWS_ENDPOINT=
# OSS_AWS_CDN_DOMAIN=