<view class="member-code-page">
  <!-- 未登录状态 -->
  <view wx:if="{{!isLoggedIn}}" class="not-logged-in">
    <view class="not-logged-in-icon">🔐</view>
    <text class="not-logged-in-text">登录后查看会员码</text>
    <button class="login-btn" bindtap="goToLogin">去登录</button>
  </view>

  <!-- 已登录状态 -->
  <view wx:else class="member-code-content">
    <!-- 加载状态 -->
    <view wx:if="{{loading}}" class="loading-state">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>

    <!-- 会员码卡片 -->
    <view wx:elif="{{memberCode}}" class="code-card">
      <!-- 卡片头部 -->
      <view class="card-top">
        <image class="card-logo" src="/assets/images/logo-baker.png" mode="aspectFit" />
        <view class="card-info">
          <text class="card-brand">吉世面包</text>
          <text class="card-label">向店员出示会员码</text>
        </view>
        <view class="refresh-btn" bindtap="refreshMemberCode">
          <text class="refresh-icon">🔄</text>
          <text class="refresh-text">刷新</text>
        </view>
      </view>

      <!-- 二维码区域 -->
      <view class="qrcode-area">
        <canvas 
          type="2d" 
          id="qrcodeCanvas" 
          class="qrcode-canvas"
        ></canvas>
      </view>

      <!-- 会员编号 -->
      <view class="member-no">
        <text class="member-no-label">会员编号</text>
        <text class="member-no-value">{{memberCode.code}}</text>
      </view>

      <!-- 条形码区域 -->
      <view class="barcode-area">
        <canvas 
          type="2d" 
          id="barcodeCanvas" 
          class="barcode-canvas"
        ></canvas>
      </view>

      <!-- 倒计时 -->
      <view class="countdown-bar">
        <text class="countdown-label">有效期剩余</text>
        <text class="countdown-value">{{countdownText}}</text>
      </view>
    </view>

    <!-- 错误状态 -->
    <view wx:elif="{{error}}" class="error-state">
      <text class="error-icon">⚠️</text>
      <text class="error-text">{{error}}</text>
      <button class="retry-btn" bindtap="loadMemberCode">重试</button>
    </view>
  </view>
</view>