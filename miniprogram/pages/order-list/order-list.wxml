<view class="order-list-container">
  <!-- Tab 栏 -->
  <view class="tab-bar">
    <view 
      wx:for="{{tabList}}" 
      wx:key="{{item.key}}"
      class="tab-item {{currentTab === item.key ? 'active' : ''}}"
      bindtap="switchTab"
      data-tab="{{item.key}}"
    >
      {{item.name}}
    </view>
  </view>

  <!-- 订单列表 -->
  <view class="order-content">
    <!-- 空状态 -->
    <view wx:if="{{orderList.length === 0 && !loading}}" class="empty-state">
      <view class="empty-illustration">
        <!--<text class="empty-clipboard">📋</text>
        <text class="empty-figure">🧑‍🍳</text>-->
        <image class="empty-clipboard" src="/assets/images/empty-order.png" mode="aspectFit" />
      </view>
      <text class="empty-text">您暂时还没有订单哦~</text>
      <button class="go-order-btn" bindtap="goToOrder">去下单</button>
    </view>

    <!-- 订单列表 -->
    <view wx:else>
      <view 
        wx:for="{{orderList}}" 
        wx:key="{{item.orderId}}"
        class="order-card"
        bindtap="goToDetail"
        data-order-id="{{item.orderId}}"
      >
        <!-- 订单头部 -->
        <view class="order-header">
          <view class="order-id">订单号：{{item.orderId}}</view>
          <view class="order-status">{{item.status}}</view>
        </view>

        <!-- 商品信息 -->
        <view class="order-items">
          <view wx:for="{{item.items}}" wx:key="{{index}}" class="order-item">
            <view class="item-info">
              <text class="item-name">{{item.name}}</text>
              <text class="item-quantity">x{{item.quantity}}</text>
            </view>
            <text class="item-price">¥{{item.price}}</text>
          </view>
        </view>

        <!-- 订单底部 -->
        <view class="order-footer">
          <view class="order-time">{{item.createTime}}</view>
          <view class="order-amount">
            <text class="amount-label">合计：</text>
            <text class="amount-value">¥{{item.totalAmount}}</text>
          </view>
        </view>
      </view>

      <!-- 加载更多 -->
      <view wx:if="{{loading && orderList.length > 0}}" class="loading-more">
        <text>加载中...</text>
      </view>

      <!-- 没有更多数据 -->
      <view wx:if="{{!hasMore && orderList.length > 0}}" class="no-more">
        <text>没有更多数据了</text>
      </view>
    </view>
  </view>
</view>