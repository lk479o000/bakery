<view class="store-list-page">
  <!-- Tab栏：选择门店 / 常去收藏 -->
  <view class="tab-bar">
    <view class="tab-item {{currentTab === 'select' ? 'active' : ''}}" bindtap="onTabChange" data-tab="select">
      <text>选择门店</text>
    </view>
    <view class="tab-item {{currentTab === 'favorite' ? 'active' : ''}}" bindtap="onTabChange" data-tab="favorite">
      <text>常去/收藏门店</text>
    </view>
  </view>

  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrap">
      <text class="search-icon">🔍</text>
      <input 
        class="search-input" 
        placeholder="搜索" 
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearch"
      />
    </view>
  </view>

  <!-- 地图区域 -->
  <view class="map-section" wx:if="{{currentTab === 'select'}}">
    <map 
      class="store-map"
      latitude="{{mapLatitude}}"
      longitude="{{mapLongitude}}"
      scale="14"
      markers="{{markers}}"
      show-location
      bindmarkertap="onMarkerTap"
    ></map>
    <view class="map-collapse" bindtap="onToggleMap">
      <text>{{mapCollapsed ? '展开地图' : '收起地图'}} {{mapCollapsed ? '▼' : '^'}}</text>
    </view>
  </view>

  <!-- 门店列表 -->
  <scroll-view class="store-list" scroll-y enhanced show-scrollbar="{{false}}">
    <!-- 空状态 -->
    <view wx:if="{{storeList.length === 0 && !loading}}" class="empty-state">
      <text class="empty-text">暂无门店信息</text>
    </view>

    <!-- 门店卡片 -->
    <view 
      wx:for="{{storeList}}" 
      wx:key="id"
      class="store-card"
    >
      <view class="store-header">
        <view class="store-name-row">
          <text class="store-name">{{item.name}}</text>
          <view class="store-status {{item.isOpen ? 'open' : 'closed'}}">
            <text>{{item.isOpen ? '营业中' : '休息中'}}</text>
          </view>
        </view>
        <view class="store-tags">
          <text wx:if="{{item.canDelivery}}" class="store-tag">可外送</text>
          <text wx:if="{{item.canPickup}}" class="store-tag">可自取</text>
          <text wx:if="{{item.canExpress}}" class="store-tag">可快递</text>
        </view>
      </view>

      <view class="store-details">
        <view class="store-detail-item">
          <text class="detail-icon">📍</text>
          <text class="detail-text">{{item.address}}</text>
        </view>
        <view class="store-detail-item">
          <text class="detail-icon">🕐</text>
          <text class="detail-text">{{item.businessHours}}</text>
        </view>
      </view>

      <view class="store-actions">
        <view class="store-action-left">
          <view class="action-order" bindtap="onGoOrder" data-store-id="{{item.id}}" data-store-name="{{item.name}}">
            <text class="order-text">去下单</text>
          </view>
          <text class="store-distance">距离 {{item.distance}}</text>
        </view>
        <view class="store-action-btns">
          <view class="action-circle-btn" bindtap="onCallStore" data-phone="{{item.phone}}">
            <text>📞</text>
          </view>
          <view class="action-circle-btn" bindtap="onNavigate" data-latitude="{{item.latitude}}" data-longitude="{{item.longitude}}" data-name="{{item.name}}" data-address="{{item.address}}">
            <text>🧭</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 加载更多 -->
    <view wx:if="{{loading}}" class="loading-more">
      <text>加载中...</text>
    </view>
  </scroll-view>
</view>
