<view class="address-container">
  <!-- 未登录状态 -->
  <view wx:if="{{ !isLoggedIn }}" class="not-logged-in">
    <view class="not-logged-in-icon">🔒</view>
    <view class="not-logged-in-text">请先登录</view>
    <button bindtap="goToLogin" class="login-button">去登录</button>
  </view>

  <!-- 已登录状态 -->
  <view wx:else>
    <!-- 地址列表 -->
    <view wx:if="{{ addresses.length > 0 }}" class="address-list">
      <view wx:for="{{ addresses }}" wx:key="{{ item.id }}" class="address-item">
        <view class="address-header">
          <view class="name-phone">
            <text class="name">{{ item.name }}</text>
            <text class="phone">{{ item.phone }}</text>
          </view>
          <view wx:if="{{ item.isDefault }}" class="default-tag">默认</view>
        </view>
        <view class="address-content">
          <text>{{ item.province }}{{ item.city }}{{ item.district }}{{ item.detail }}</text>
        </view>
        <view class="address-footer">
          <button wx:if="{{ !item.isDefault }}" bindtap="setDefaultAddress" data-id="{{ item.id }}" class="default-button">设为默认</button>
          <button bindtap="editAddress" data-id="{{ item.id }}" class="edit-button">编辑</button>
          <button bindtap="deleteAddress" data-id="{{ item.id }}" class="delete-button">删除</button>
        </view>
      </view>
    </view>

    <!-- 空地址状态 -->
    <view wx:else class="empty-address">
      <view class="empty-icon">📦</view>
      <view class="empty-text">暂无地址</view>
      <button bindtap="addAddress" class="add-button">新增地址</button>
    </view>

    <!-- 底部新增地址按钮 -->
    <view class="add-address-container">
      <button bindtap="addAddress" class="add-address-button">+ 新增地址</button>
    </view>
  </view>
</view>